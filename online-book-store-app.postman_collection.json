{
  "info": {
    "_postman_id": "bookstore-collection-001",
    "name": "Bookstore API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register new user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@email.com\",\n  \"password\": \"12345678\",\n  \"repeatedPassword\": \"12345678\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@email.com\",\n  \"password\": \"12345678\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get current user info",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Update user info",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Updated\",\n  \"lastName\": \"User\"\n}"
            },
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Get all users (ADMIN)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/users"
          }
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "name": "Add new book (ADMIN)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Clean Code\",\n  \"author\": \"Robert C. Martin\",\n  \"isbn\": \"9780132350884\",\n  \"price\": 29.99,\n  \"categoryId\": 1,\n  \"description\": \"A handbook of agile software craftsmanship.\"\n}"
            },
            "url": "{{baseUrl}}/api/books"
          }
        },
        {
          "name": "Get all books",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/books" }
        },
        {
          "name": "Get book by ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/books/1" }
        },
        {
          "name": "Update book (ADMIN)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Clean Coder\",\n  \"author\": \"Robert C. Martin\",\n  \"isbn\": \"9780137081073\",\n  \"price\": 34.99,\n  \"categoryId\": 1,\n  \"description\": \"A Code of Conduct for Professional Programmers.\"\n}"
            },
            "url": "{{baseUrl}}/api/books/1"
          }
        },
        {
          "name": "Delete book (ADMIN)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/books/1"
          }
        }
      ]
    },
    {
      "name": "Shopping Cart",
      "item": [
        {
          "name": "View cart",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/cart"
          }
        },
        {
          "name": "Add book to cart",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookId\": 1,\n  \"quantity\": 2\n}"
            },
            "url": "{{baseUrl}}/api/cart"
          }
        },
        {
          "name": "Update cart item quantity",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"bookId\": 1,\n  \"quantity\": 3\n}" },
            "url": "{{baseUrl}}/api/cart"
          }
        },
        {
          "name": "Remove book from cart",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/cart/1"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Place new order",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": "{{baseUrl}}/api/orders"
          }
        },
        {
          "name": "View my orders",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/orders"
          }
        },
        {
          "name": "View order by ID",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "GET",
            "url": "{{baseUrl}}/api/orders/1"
          }
        },
        {
          "name": "Update order status (ADMIN)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"SHIPPED\"\n}" },
            "url": "{{baseUrl}}/api/orders/1"
          }
        }
      ]
    }
  ]
}
